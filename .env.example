# =========================
# App / Server
# =========================
NODE_ENV=development
PORT=3000

# Comma-separated allow-list for CORS in production
# Example: https://lumu.vercel.app,https://www.lumu.com
FRONTEND_ORIGINS=http://localhost:3000

# =========================
# Supabase
# =========================
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Preferred for backend writes/admin access
SUPABASE_SERVICE_ROLE_KEY=
# Backward-compat alias (optional)
SUPABASE_SERVICE_KEY=

# =========================
# Stripe
# =========================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PAYMENT_LINK=
STRIPE_B2B_PAYMENT_LINK=

# =========================
# Admin
# =========================
ADMIN_API_KEY=

# Feature Flags
LOCAL_PRICE_EXTRACTION=false

# =========================
# AI / Search APIs
# =========================
GEMINI_API_KEY=
SERPER_API_KEY=

# =========================
# Affiliate
# =========================
ML_AFFILIATE_CAMPAIGN=
ALIEXPRESS_AFFILIATE_KEY=
